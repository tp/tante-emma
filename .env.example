# Copy to .env and fill in. Render injects these in production.

# Render managed Postgres connection string
DATABASE_URL=

# Anthropic — merchant message parsing (M2+) and storefront restyle CSS generation
ANTHROPIC_API_KEY=

# OpenAI — gpt-image-2 banner + printable menu-poster generation (restyle flow, optional)
OPENAI_API_KEY=

# Twilio WhatsApp sandbox (M1+)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Stripe test mode (M5, optional)
STRIPE_SECRET_KEY=

# Public origin of the deployed app, no trailing slash, e.g. https://tante-emma.onrender.com
PUBLIC_BASE_URL=http://localhost:3000

# Port (Render sets this automatically)
PORT=3000
